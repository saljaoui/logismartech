{
  "name": "logismartech-backend",
  "version": "1.0.0",
  "description": "AI-powered logistics backend MVP for LogiSmartech",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev --name init",
    "seed": "node prisma/seed.js",
    "db:init": "npm run prisma:generate && npm run prisma:push && npm run seed"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "openai": "^4.76.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.7",
    "prisma": "^7.8.0"
  },
  "engines": {
    "node": ">=20"
  }
}
